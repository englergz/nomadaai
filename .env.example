# ===== Backend (services/api) =====
# Carpeta con los artefactos de Research (por defecto ../../../Research)
# RESEARCH_DIR=/ruta/a/appNomadaAI/Research
ENVIRONMENT=development
# Limita trayectorias cargadas en memoria (0 = todas). Útil en tier gratuito.
MAX_TRAJECTORIES=0
# Orígenes permitidos por CORS (frontend)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Base de datos (opcional en esta fase; necesaria para ETL/producción)
# DATABASE_URL=postgresql://user:pass@host:5432/db

# ===== Frontend (apps/web) — ver apps/web/.env.example =====
# VITE_API_URL=http://localhost:8000
